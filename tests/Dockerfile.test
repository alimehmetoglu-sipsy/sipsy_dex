# Dockerfile for Test Runner
FROM python:3.11-slim

# Set working directory
WORKDIR /tests

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    git \
    postgresql-client \
    build-essential \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install Playwright browsers
RUN playwright install --with-deps chromium firefox webkit

# Create directories for test results and logs
RUN mkdir -p /tests/results /tests/logs

# Copy test files
COPY . .

# Set environment variables
ENV PYTHONPATH=/tests
ENV PYTEST_ADDOPTS="--html=/tests/results/report.html --self-contained-html --junitxml=/tests/results/junit.xml"

# Create entrypoint script
RUN echo '#!/bin/bash\n\
set -e\n\
\n\
echo "Starting DexAgent Test Runner..."\n\
echo "Python version: $(python --version)"\n\
echo "Pytest version: $(pytest --version)"\n\
\n\
# Wait for services to be ready\n\
echo "Waiting for services to be ready..."\n\
python /tests/scripts/wait_for_services.py\n\
\n\
# Run the specified test suite or all tests\n\
if [ "$1" = "integration" ]; then\n\
    echo "Running integration tests..."\n\
    pytest /tests/integration -v --tb=short -m "not slow"\n\
elif [ "$1" = "performance" ]; then\n\
    echo "Running performance tests..."\n\
    pytest /tests/performance -v --tb=short\n\
elif [ "$1" = "e2e" ]; then\n\
    echo "Running E2E tests..."\n\
    pytest /tests/e2e -v --tb=short\n\
elif [ "$1" = "smoke" ]; then\n\
    echo "Running smoke tests..."\n\
    pytest -v --tb=short -m "smoke"\n\
elif [ "$1" = "all" ]; then\n\
    echo "Running all tests..."\n\
    pytest /tests -v --tb=short\n\
else\n\
    echo "Usage: $0 {integration|performance|e2e|smoke|all}"\n\
    echo "Running all tests by default..."\n\
    pytest /tests -v --tb=short\n\
fi\n\
\n\
echo "Test execution completed."\n\
' > /tests/entrypoint.sh && chmod +x /tests/entrypoint.sh

# Default command
CMD ["/tests/entrypoint.sh", "all"]